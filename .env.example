# Groly Konfiguration
# Diese Datei als .env kopieren und anpassen

# Datenbank (Docker Volume wird empfohlen)
DATABASE_URL=/app/data/groly.db

# Admin-User (wird beim ersten Start angelegt, falls keine User vorhanden)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# In Production auf true setzen (sichere Cookies)
NODE_ENV=production

# Web Push (VAPID) - mit `node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"` generieren
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@groly.local
# Gleicher Wert wie VAPID_PUBLIC_KEY (wird im Browser verwendet)
PUBLIC_VAPID_PUBLIC_KEY=
