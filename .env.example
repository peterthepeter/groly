# Groly Konfiguration
# Diese Datei als .env kopieren und anpassen

# Datenbank (Docker Volume wird empfohlen)
DATABASE_URL=/app/data/groly.db

# Admin-User (wird beim ersten Start angelegt, falls keine User vorhanden)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# In Production auf true setzen (sichere Cookies)
NODE_ENV=production
